<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/nostr_sync_watch_history_switch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/nostr_sync_watch_history_toggle" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/nostr_sync_subscriptions_switch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/nostr_sync_subscriptions_toggle" />

        <Button
            android:id="@+id/nostr_sign_in_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/nostr_sign_in" />

        <LinearLayout
            android:id="@+id/nostr_identity_actions_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:visibility="gone">

            <Button
                android:id="@+id/nostr_show_identity_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/nostr_show_keys" />

            <Button
                android:id="@+id/nostr_clear_identity_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/nostr_clear_identity" />
        </LinearLayout>

        <TextView
            android:id="@+id/nostr_relays_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/nostr_relays_title"
            android:textAppearance="@style/TextAppearance.AppCompat.Title" />

        <TextView
            android:id="@+id/nostr_relays_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/nostr_relays_subtitle"
            android:textAppearance="@style/TextAppearance.AppCompat.Body2" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/nostr_add_relay_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/nostr_add_relay" />

            <Button
                android:id="@+id/nostr_reset_relays_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/nostr_reset_relays" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nostr_relays_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            tools:ignore="UselessParent" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
